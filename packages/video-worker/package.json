{
  "name": "video-worker",
  "version": "1.0.0",
  "description": "Video Worker - Remotion-based video generation from audio and script data for automated radio podcast pipeline",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@video-factory/shared": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.43",
    "@remotion/cli": "4.0.419",
    "@remotion/media": "4.0.419",
    "@remotion/renderer": "4.0.419",
    "@remotion/tailwind-v4": "4.0.419",
    "effect": "4.0.0-beta.43",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.419",
    "tailwindcss": "4.0.0",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@remotion/bundler": "4.0.419",
    "@remotion/eslint-config-flat": "4.0.419",
    "@types/node": "^20.11.0",
    "@types/react": "19.2.7",
    "eslint": "9.19.0",
    "fast-check": "^3.23.2",
    "happy-dom": "^20.5.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.0",
    "zod-fast-check": "^0.10.1"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "render": "MOCK_MODE=true tsx src/entrypoints/local.ts --output output/video.mp4",
    "lint": "eslint src && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run --testPathPattern=integration",
    "test:e2e": "RUN_E2E_TESTS=true vitest run e2e.test.ts",
    "test:perf": "RUN_PERF_TESTS=true vitest run performance.test.ts",
    "test:errors": "RUN_ERROR_TESTS=true vitest run error-scenarios.test.ts",
    "test:fuzzing": "RUN_FUZZING_TESTS=true vitest run fuzzing.test.ts",
    "test:all-extended": "RUN_E2E_TESTS=true RUN_PERF_TESTS=true RUN_ERROR_TESTS=true RUN_FUZZING_TESTS=true vitest run"
  },
  "sideEffects": [
    "*.css"
  ]
}
